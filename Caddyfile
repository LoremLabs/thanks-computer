# Caddy in front of the chassis. Local dev variant; for production, swap localhost
# for your domain and Caddy will provision Let's Encrypt certs automatically.
#
# Run with: caddy run --config Caddyfile

localhost:8443 {
	tls internal

	reverse_proxy localhost:8080
}

